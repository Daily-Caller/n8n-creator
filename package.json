{
  "name": "@daily-caller/n8n-creator",
  "version": "1.2.0",
  "description": "Secure n8n workflow builder — CI gates, pattern learning, multi-IDE support, and mandatory TDD audit on every build",
  "keywords": [
    "n8n",
    "workflow",
    "automation",
    "security",
    "tdd",
    "audit",
    "claude",
    "gemini",
    "cursor",
    "ai-agent",
    "skill",
    "webhook",
    "ci",
    "deploy"
  ],
  "homepage": "https://github.com/daily-caller/n8n-creator",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daily-caller/n8n-creator.git"
  },
  "license": "MIT",
  "bin": {
    "n8n-creator": "bin/n8n-creator.js"
  },
  "main": "./lib/cli.js",
  "files": [
    "bin/",
    "lib/",
    "ci/",
    "references/",
    "workflows/_templates/",
    "workflows/launch-all.sh",
    "scripts/",
    "SKILL.md",
    ".env.example",
    "gitignore"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "tdd-audit": "tdd-audit",
    "audit": "tdd-audit",
    "health": "node bin/n8n-creator.js health",
    "launch-all": "bash workflows/launch-all.sh"
  },
  "dependencies": {
    "@lhi/tdd-audit": "^1.4.1",
    "dotenv": "^16.4.7"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "vitest": "^4.1.1"
  }
}
