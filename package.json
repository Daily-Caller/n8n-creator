    "workflow",
    "automation",
    "security",
    "tdd",
    "audit",
    "claude",
    "ai-agent",
    "skill",
    "webhook"
  ],
  "homepage": "https://github.com/lcanady/n8n-creator",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lcanady/n8n-creator.git"
  },
  "license": "MIT",
  "bin": {
    "n8n-creator": "bin/n8n-creator.js"
  },
