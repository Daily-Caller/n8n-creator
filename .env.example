# n8n-creator .env — DO NOT COMMIT THIS FILE
# Copy to .env and fill in your values

# ── n8n Instance ─────────────────────────────────────────────────────────────
N8N_API_URL=http://localhost:5678          # Base URL (no trailing slash)
N8N_API_KEY=your-api-key-here             # Settings > n8n API > Create API key
N8N_WEBHOOK_BASE_URL=https://n8n.yourdomain.com  # Public URL (if behind proxy)

# ── Encryption (CRITICAL for self-hosted prod) ────────────────────────────────
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# ── Security ──────────────────────────────────────────────────────────────────
N8N_BLOCK_ENV_ACCESS_IN_NODE=true         # Block process.env in Code nodes
N8N_SECURE_COOKIE=true
N8N_PAYLOAD_SIZE_MAX=16                   # MiB

# ── Database (PostgreSQL recommended for prod) ────────────────────────────────
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=
DB_POSTGRESDB_SSL_ENABLED=true

# ── Execution ─────────────────────────────────────────────────────────────────
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168               # Hours (7 days)
EXECUTIONS_TIMEOUT=300                    # Seconds

# ── Skill ─────────────────────────────────────────────────────────────────────
WORKFLOWS_DIR=./workflows                 # Where workflow JSON + scripts are saved
